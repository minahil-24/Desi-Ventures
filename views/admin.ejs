<!DOCTYPE html>
<html>
<head>
    <title>Admin Cart</title>
    <style>
        .admin-heading {
            font-size: 26px;
            margin-bottom: 10px;
            font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
            border-top: 2px solid black;
            border-bottom: 2px solid black;
            text-align: center;
        }

        .section {
            display: inline-block;
            margin-right: 20px;
        }

        .section-heading {
            cursor: pointer;
            font-size: 18px;
            margin-bottom: 5px;
            background-color: orange;
            color: white;
            padding: 10px;
            border-radius: 5px;
        }

        .section-content {
            display: none;
            float: left;
        }

        .section-content.show {
            display: block;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th, td {
            border: 1px solid black;
            padding: 8px;
            text-align: left;
        }

        th {
            background-color: #f2f2f2;
        }

        .item-container {
            margin-bottom: 20px;
            border: 1px solid #ccc;
            padding: 10px;
            border-radius: 5px;
        }

        .item-heading {
            font-size: 20px;
            margin-bottom: 10px;
        }

        .update-button {
            background-color: blue;
            color: white;
            padding: 5px 10px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <!-- Admin Section -->
    <div class="admin-section">
        <div class="admin-heading">Only Admin can View</div>

        <div class="item-container" id="chickenTikka">
            <div class="item-heading">Chicken Tikka</div>
            <button class="update-button" onclick="openUpdatePage('chickenTikka')">Update</button>
        </div>

        <div class="item-container" id="tikkaKarahi">
            <div class="item-heading">Tikka Karahi</div>
            <button class="update-button" onclick="openUpdatePage('tikkaKarahi')">Update</button>
        </div>

        <!-- Existing sections -->
        <div class="section" id="userDetails">
            <div class="section-heading" onclick="toggleSection('userDetails')">Customer Details</div>
            <div class="section-content" id="userDetailsContent">
                <!-- Content for User Details -->
                <table style="width: 700px;">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Password</th>
                            <th>Admin</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Insert user details dynamically -->
                        <% users.forEach(function(user) { %>
                            <tr id="user-<%= user._id %>">
                                <td><%= user.username %></td>
                                <td><%= user.password %></td>
                                <td><%= user.admin %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="section" id="orderDetails">
            <div class="section-heading" onclick="toggleSection('orderDetails')">Order Details</div>
            <div class="section-content" id="orderDetailsContent">
                <!-- Content for Order Details -->
                <table style="width: 700px;">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Total Amount</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Insert order details dynamically -->
                        <% cartItems.forEach(function(cartItem) { %>
                            <tr id="cart-item-<%= cartItem._id %>">
                                <td><%= cartItem.name %></td>
                                <td><%= cartItem.quantity %></td>
                                <td><%= cartItem.price %></td>
                                <td><%= cartItem.totalAmount %></td>
                                <td>
                                    <!-- Delete Form -->
                                    <form action="/delete/<%= cartItem._id %>" method="POST" style="display:inline;">
                                        <button type="submit">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="section" id="placeOrder">
            <div class="section-heading" onclick="toggleSection('placeOrder')">Place Order</div>
            <div class="section-content" id="placeOrderContent">
                <!-- Content for Place Order -->
                <table style="width: 700px;">
                    <thead>
                        <tr>
                            <th>Mobile</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Address</th>
                            <th>Instructions</th>
                            <th>Payment Method</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Insert order details dynamically -->
                        <% orders.forEach(function(order) { %>
                            <tr>
                                <td><%= order.mobile %></td>
                                <td><%= order.fullname %></td>
                                <td><%= order.email %></td>
                                <td><%= order.address %></td>
                                <td><%= order.instructions %></td>
                                <td><%=order.paymentMethod %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        function toggleSection(sectionId) {
            const sectionContent = document.getElementById(sectionId + 'Content');
            sectionContent.classList.toggle('show');
        }

        function openUpdatePage(itemId) {
            window.location.href = `/update/${itemId}`;
        }
    </script>
</body>
</html>
