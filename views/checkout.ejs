    <script >

    document.addEventListener('DOMContentLoaded', function () {
        const tipButtons = document.querySelectorAll('.tip-button');
        const otherTipInput = document.getElementById('other-tip');
    
        tipButtons.forEach(button => {
            button.addEventListener('click', function () {
                const tipAmount = parseFloat(this.textContent);
                updateTotal(tipAmount);
            });
        });
    
        otherTipInput.addEventListener('input', function () {
            const tipAmount = parseFloat(this.value) || 0;
            updateTotal(tipAmount);
        });
    });
        function updateTotal(tipAmount) {
            const subTotal = 31320;
            const totalElement = document.querySelector('.price-summary strong');
            const newTotal = subTotal + tipAmount;
            totalElement.textContent = `Total: Rs. ${newTotal.toFixed(2)}`;
        }
        
        function placeOrder() {
    // Retrieve values from HTML elements
    const mobile = document.getElementById('mobile').value;
    const fullname = document.getElementById('fullname').value;
    const email = document.getElementById('email').value;
    const address = document.getElementById('address').value;
    const instructions = document.getElementById('instructions').value;

    let tipAmount = 0;
    const tipButtons = document.querySelectorAll('.tip-button');
    tipButtons.forEach(button => {
        if (button.classList.contains('selected')) {
            tipAmount = parseInt(button.textContent);
        }
    });

    const otherTip = document.getElementById('other-tip').value;
    if (otherTip.trim() !== '') {
        tipAmount = parseInt(otherTip);
    }

    const paymentMethod = document.querySelector('input[name="payment-method"]:checked').id;
    const cashChangeRequest = document.getElementById('cash-change-input').value;

   
    // Example total amount calculation (you should adjust this based on your application logic)
    const totalAmount = 31320; // Example total amount

    // Prepare the data to send in the POST request
    const data = {
        mobile,
        fullname,
        email,
        address,
        instructions,
       
        paymentMethod,
        
        totalAmount
    };

    // Send POST request to server
    fetch('/place-order', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
    })
    .then(response => {
        if (!response.ok) {
            throw new Error('Network response was not ok');
        }
        return response.json();
    })
    .then(data => {
        console.log('Success:', data);
        // Show success message
        alert('Your order has been placed.');
        // Redirect to /home
        window.location.href = '/home';
    })
    .catch(error => {
        console.error('Error:', error);
        // Show error message
        alert('Failed to place order. Please try again later.');
    });
}

