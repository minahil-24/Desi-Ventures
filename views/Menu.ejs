                var pricep = parseFloat(document.getElementById('productPrice').textContent.replace("Price: ", ""));
            
                document.getElementById('empty').style.display = "none";
                document.getElementById('checkoutButton').style.display = "block";
                addProductToCart(namep, count, pricep);   
            }
        }
        
        function updateTotalAmount(price) {
    totalAmount += price;
    document.querySelector('.total-amount').textContent = 'Rs.' + totalAmount.toFixed(2);

    // Send the updated total amount to the server
    fetch('/update-total-amount', {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ totalAmount: totalAmount })
    })
    .then(response => response.json())
    .then(data => {
        console.log('Total amount updated successfully on server:', data);
    })
    .catch((error) => {
        console.error('Error updating total amount on server:', error);
    });
}
        function DeductTotalAmount(price) {
            totalAmount - price;
            document.querySelector('.total-amount').textContent = 'Rs.' + totalAmount.toFixed(2);
        }
        function addProductToCart(name, quantity, price) {
    const cartItems = document.getElementById('cartItems');
    const existingItems = cartItems.getElementsByClassName('product-item');
    let productExists = false;

    for (let i = 0; i < existingItems.length; i++) {
        const productName = existingItems[i].getElementsByClassName('product-name')[0].textContent;
        if (productName === name) {
            const productQuantity = existingItems[i].getElementsByClassName('product-quantity')[0];
            const productAmount = existingItems[i].getElementsByClassName('product-amount')[0];

            let newQuantity = parseInt(productQuantity.textContent) + quantity;
            let newAmount = newQuantity * price;

            productQuantity.textContent = newQuantity;
            productAmount.textContent = 'Rs.' + newAmount.toFixed(2);

            updateTotalAmount(price * quantity);
            productExists = true;
            break;
        }
    }

    if (!productExists) {
        const productItem = document.createElement('div');
        productItem.className = 'product-item';

        const productName = document.createElement('div');
        productName.className = 'product-name';
        productName.textContent = name;

        const productQuantity = document.createElement('div');
        productQuantity.className = 'product-quantity';
        productQuantity.textContent = quantity;

        const productAmount = document.createElement('div');
        productAmount.className = 'product-amount';
        productAmount.textContent = 'Rs.' + (price * quantity).toFixed(2);

        productItem.appendChild(productName);
        productItem.appendChild(productQuantity);
        productItem.appendChild(productAmount);
        cartItems.appendChild(productItem);

        updateTotalAmount(price * quantity);
    }
}
function showSlider(image, price, name) {
    var sliderContainer = document.getElementById("sliderContainer");
    var productImage = document.getElementById("productImage");
    var productName = document.getElementById("productName");
    var productPrice = document.getElementById("productPrice");
    var quantityInput = document.getElementById("quantity");
    document.body.style.overflow = 'hidden'; // Disable scrolling
    productImage.src = image;
    productName.textContent = name;
    productPrice.textContent = "Price: " + price.toFixed(2);
    quantityInput.value = 1;
    document.getElementById("overlay").style.display = "block";
    sliderContainer.style.right = "0";
    document.body.style.backgroundColor = "#cccccc";
}

function hideSlider() {
    var sliderContainer = document.getElementById("sliderContainer");
    sliderContainer.style.right = "-500px";
    document.body.style.backgroundColor = "#f4f4f4";
    document.body.style.overflow = ''; // enable scrolling
    document.getElementById("overlay").style.display = "none";
}

function decrementQuantity() {
    var quantityInput = document.getElementById("quantity");
    var quantity = parseInt(quantityInput.value);
    if (quantity > 1) {
        quantityInput.value = quantity - 1;
    }
}

function incrementQuantity() {
    var quantityInput = document.getElementById("quantity");
    var quantity = parseInt(quantityInput.value);
    if (quantity < 15) {
        quantityInput.value = quantity + 1;
    }
}

function addToCart() {
    hideSlider();
    var quantity = parseInt(document.getElementById("quantity").value);
    var name = document.getElementById("productName").textContent;
    var price = parseFloat(document.getElementById("productPrice").textContent.replace("Price: ", ""));
    var totalAmount = quantity * price;
 // Create a new Date object
 let currentDateTime = new Date();

// Get the current date and time as a localized string
let formattedDateTime = currentDateTime.toLocaleString();

console.log(formattedDateTime); // Output: "6/15/2024, 2:05:30 PM" (or the current date and time based on locale)
    fetch('/add-to-cart', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ name, quantity, price, totalAmount })
    })
    .then(response => response.json())
    .then(data => {
        console.log('Success:', data);
        updateItemCount(quantity);
    })
    .catch((error) => {
        console.error('Error:', error);
    });
}




